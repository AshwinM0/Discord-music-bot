# Discord Bot Token (required)
# Get yours at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# --- Optional Overrides ---
# Change the command prefix (default: <>)
# COMMAND_PREFIX=<>

# Change the max queue size (default: 50)
# MAX_QUEUE_SIZE=50

# Change the inactivity timeout in seconds before the bot leaves a VC (default: 120)
# INACTIVITY_TIMEOUT=120

# Spotify credentials (reserved for future use)
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret